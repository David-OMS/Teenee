# OpenAI
OPENAI_API_KEY=
# Optional Realtime overrides
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
# Voice: coral, shimmer, or sage (female-leaning). Also: alloy, ash, ballad, echo, verse, marin, cedar
OPENAI_REALTIME_VOICE=coral

# Supabase — Project Settings → API
# IMPORTANT: secret key = service_role (server only). NOT the anon/publishable key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=teenee
R2_PUBLIC_URL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# V1 auth: dev (single user) | supabase (future magic link)
TEENEE_AUTH_MODE=dev
